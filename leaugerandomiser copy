#Class parent for randomisers, to make it easier to make more randomisers in the future, and to make it easier to change the randomiser if needed.

class randomiserparent:
    def __init__(self, randomiser):
        self.randomiser = randomiser

    def randomise(self):  
        return random.choice(self.randomiser.names)


#Randomiser for champions, uses the parent class to make it easier to make more randomisers in the future, and to make it easier to change the randomiser if needed.    
class championrandomiser(randomiserparent):
    def __init__(self):
        super().__init__(randomiser=self)
        self.names = names
#Randomiser for runes, uses the parent class to make it easier to make more randomisers in the future, and to make it easier to change the randomiser if needed.
class runerandomiser(randomiserparent):
    def __init__(self):
        super().__init__(randomiser=self)
        self.names = list(rune_map.keys())

class runetree:
    def __init__(self, tree_name):
        self.tree = rune_map[tree_name]

    def primary(self):
        return {
            "Keystone": random.choice(self.tree["main"]),
            "Sub1": random.choice(self.tree["sub1"]),
            "Sub2": random.choice(self.tree["sub2"]),
            "Sub3": random.choice(self.tree["sub3"]),
        }

    def secondary(self):
        # Pick 2 different sub slots
        slots = random.sample(["sub1", "sub2", "sub3"], 2)

        return {
            slots[0]: random.choice(self.tree[slots[0]]),
            slots[1]: random.choice(self.tree[slots[1]]),
        }
    
class lanerandomiser(randomiserparent):
    def __init__(self):
        super().__init__(randomiser=self)
        self.names = ("Top","Jungle","Mid","ADC","Support")

def generate_build():

    champion = championrandomiser().randomise()

    primary_tree, secondary_tree = random.sample(
    list(rune_map.keys()),
    2
)

    output = f"""
Champion: {champion}

Primary: {primary_tree}
Runes: {runetree(primary_tree).primary()}

Secondary: {secondary_tree}
Runes: {runetree(secondary_tree).secondary()}
"""

    result.config(text=output)

